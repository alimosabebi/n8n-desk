  <!-- Error Modal -->
  <div id="modal-error" class="modal-overlay" aria-hidden="true">
    <div class="modal">
      <div class="modal-icon modal-icon--error">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h3>Something went wrong</h3>
      <p id="modal-error-message">Please try again in a moment.</p>
      <button class="modal-close" data-dismiss="modal">Close</button>
    </div>
  </div>

  <script is:inline>
    // ------- CONFIG -------
    var WEBHOOK_URL = 'https://let-the-work-flow.app.n8n.cloud/webhook/n8n-wait-list';

    // ------- FORM SUBMISSION -------
    var form = document.getElementById('waitlist-form');
    var emailInput = document.getElementById('waitlist-email');

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var email = emailInput.value.trim();

      if (!email || !isValidEmail(email)) {
        form.classList.add('input-error');
        emailInput.focus();
        return;
      }

      form.classList.remove('input-error');
      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, ts: new Date().toISOString() }),
      })
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          emailInput.value = '';
          showModal('modal-success');
        })
        .catch(function () {
          document.getElementById('modal-error-message').textContent =
            'Could not reach the server. Please try again in a moment.';
          showModal('modal-error');
        })
        .finally(function () {
          btn.textContent = originalText;
          btn.disabled = false;
        });
    });

    emailInput.addEventListener('input', function () {
      form.classList.remove('input-error');
    });

    function isValidEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    // ------- MODALS -------
    function showModal(id) {
      var overlay = document.getElementById(id);
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('visible');
    }

    function hideModal(overlay) {
      overlay.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('visible');
    }

    document.querySelectorAll('[data-dismiss="modal"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        hideModal(btn.closest('.modal-overlay'));
      });
    });

    document.querySelectorAll('.modal-overlay').forEach(function (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) hideModal(overlay);
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.visible').forEach(hideModal);
      }
    });

    // ------- SMOOTH SCROLL NAV -------
    document.querySelectorAll('a[href^="#"]').forEach(function (a) {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        var target = document.querySelector(a.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });

    // ------- MODE SEGMENT + CARD SYNC -------
    var allSegmentBtns = document.querySelectorAll('.mode-segment-btn');
    var tracks = document.querySelectorAll('.mode-segment-track');
    var modeCards = document.querySelectorAll('.mode-card');
    var slides = document.querySelectorAll('.screenshot-slide');
    var clouds = document.querySelectorAll('.cloud');

    function movePills(index) {
      tracks.forEach(function (track) {
        var pill = track.querySelector('.mode-segment-pill');
        var btns = track.querySelectorAll('.mode-segment-btn');
        var btn = btns[index];
        if (!pill || !btn) return;
        var trackRect = track.getBoundingClientRect();
        var btnRect = btn.getBoundingClientRect();
        pill.style.left = (btnRect.left - trackRect.left) + 'px';
        pill.style.width = btnRect.width + 'px';
      });
    }

    function setActiveMode(index) {
      movePills(index);
      allSegmentBtns.forEach(function (btn) {
        btn.classList.toggle('active', btn.getAttribute('data-index') === String(index));
      });
      modeCards.forEach(function (card) {
        card.classList.toggle('active', card.getAttribute('data-mode') === String(index));
      });
      slides.forEach(function (slide) {
        slide.classList.toggle('active', slide.getAttribute('data-slide') === String(index));
      });
      clouds.forEach(function (cloud) {
        var isActive = cloud.getAttribute('data-cloud') === String(index);
        cloud.classList.remove('cloud-active');
        if (isActive) {
          void cloud.offsetWidth;
          cloud.classList.add('cloud-active');
        }
      });
    }

    // Position pills on load
    movePills(2);

    allSegmentBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        setActiveMode(parseInt(btn.getAttribute('data-index')));
      });
    });

    modeCards.forEach(function (card) {
      card.addEventListener('click', function () {
        setActiveMode(parseInt(card.getAttribute('data-mode')));
      });
    });

    // ------- BUILDER ALIAS RETYPE -------
    (function () {
      var alias = document.getElementById('builder-alias');
      var original = 'geckse';
      var alternate = 'Dr. Pure Eval';
      var typing = false;

      function retype(from, to, done) {
        typing = true;
        var i = from.length;
        // Delete
        function del() {
          if (i <= 0) { return typeIn(); }
          i--;
          alias.textContent = from.substring(0, i);
          setTimeout(del, 40 + Math.random() * 30);
        }
        // Type
        var j = 0;
        function typeIn() {
          if (j >= to.length) { typing = false; if (done) done(); return; }
          j++;
          alias.textContent = to.substring(0, j);
          setTimeout(typeIn, 60 + Math.random() * 40);
        }
        del();
      }

      alias.parentElement.addEventListener('mouseenter', function () {
        if (typing) return;
        if (alias.textContent === original) {
          retype(original, alternate);
        }
      });

      alias.parentElement.addEventListener('mouseleave', function () {
        if (typing) return;
        if (alias.textContent === alternate) {
          retype(alternate, original);
        }
      });
    })();

    // ------- MOBILE NAV TOGGLE -------
    var navToggle = document.querySelector('.nav-mobile-toggle');
    var navLinks = document.querySelector('.nav-links');
    navToggle.addEventListener('click', function () {
      navLinks.classList.toggle('open');
    });
  </script>
</body>
</html>

<style is:global>
  /* ============================================================
     RESET & BASE
     ============================================================ */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    /* --- Neutrals (n8n primitives, pure gray HSL) --- */
    --neutral-white: hsl(0, 0%, 100%);
    --neutral-50:    hsl(0, 0%, 99%);
    --neutral-100:   hsl(0, 0%, 97.5%);
    --neutral-125:   hsl(0, 0%, 96%);
    --neutral-150:   hsl(0, 0%, 93%);
    --neutral-200:   hsl(0, 0%, 88%);
    --neutral-250:   hsl(0, 0%, 80%);
    --neutral-300:   hsl(0, 0%, 68%);
    --neutral-400:   hsl(0, 0%, 58%);
    --neutral-500:   hsl(0, 0%, 51%);
    --neutral-600:   hsl(0, 0%, 46%);
    --neutral-700:   hsl(0, 0%, 30%);
    --neutral-750:   hsl(0, 0%, 26%);
    --neutral-800:   hsl(0, 0%, 24%);
    --neutral-850:   hsl(0, 0%, 17%);
    --neutral-900:   hsl(0, 0%, 13%);
    --neutral-950:   hsl(0, 0%, 9%);

    /* --- Brand orange (n8n primary, hue 7) --- */
    --orange-300:    hsl(7, 100%, 68%);
    --orange-400:    hsl(7, 100%, 60%);
    --orange-alpha-10:  hsla(7, 100%, 68%, 0.1);
    --orange-alpha-35:  hsla(7, 100%, 68%, 0.35);

    /* --- Semantic: page surfaces (dark mode) --- */
    --page-bg:           var(--neutral-950);   /* 9%  — deepest */
    --section-alt-bg:    var(--neutral-900);   /* 13% — alternating sections */
    --surface-bg:        var(--neutral-850);   /* 17% — cards */
    --surface-raised-bg: var(--neutral-800);   /* 24% — hover, inputs */

    /* --- Semantic: text (dark mode) --- */
    --text-heading:   var(--neutral-125);  /* 96% */
    --text-body:      var(--neutral-250);  /* 80% */
    --text-muted:     var(--neutral-300);  /* 68% */
    --text-disabled:  var(--neutral-600);  /* 46% */

    /* --- Semantic: accent --- */
    --accent:         var(--orange-300);
    --accent-hover:   var(--orange-400);
    --accent-glow:    var(--orange-alpha-10);
    --accent-border:  var(--orange-alpha-35);

    /* --- Semantic: borders --- */
    --border-subtle:     rgba(255, 255, 255, 0.05);
    --border-default:    rgba(255, 255, 255, 0.1);

    /* --- Semantic: status --- */
    --success:        hsl(147, 60%, 50%);
    --success-bg:     hsla(147, 60%, 50%, 0.1);
    --error:          hsl(355, 83%, 60%);
    --error-bg:       hsla(355, 83%, 52%, 0.1);

    /* --- Layout --- */
    --max-width: 1120px;
    --section-py: 80px;
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --transition: 150ms ease;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--page-bg);
    color: var(--text-body);
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; border: none; font-family: inherit; }
  img { max-width: 100%; display: block; }

  /* ============================================================
     NAV
     ============================================================ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: hsla(0, 0%, 9%, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 18px;
    color: var(--text-heading);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .nav-links a:hover { color: var(--text-heading); }

  .nav-cta {
    background: var(--accent);
    color: var(--page-bg) !important;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-weight: 600 !important;
    transition: background var(--transition) !important;
  }

  .nav-cta:hover { background: var(--accent-hover) !important; }

  .nav-mobile-toggle {
    display: none;
    background: none;
    color: var(--text-muted);
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    position: relative;
    padding: 140px 24px var(--section-py);
    text-align: center;
    overflow: hidden;
  }

  .hero-dot-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 40%, black 20%, transparent 70%);
    pointer-events: none;
  }

  .hero > *:not(.hero-dot-grid) {
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 3px;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(40px, 6vw, 56px);
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .hero-tagline {
    font-size: 20px;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  /* --- Waitlist form --- */
  .waitlist-form {
    display: flex;
    align-items: center;
    position: relative;
    max-width: 480px;
    margin: 0 auto 56px;
    background: var(--surface-raised-bg);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition);
  }

  .waitlist-form:focus-within { border-color: var(--accent-border); }
  .waitlist-form.input-error { border-color: var(--error); }

  .waitlist-form input {
    flex: 1;
    min-width: 0;
    padding: 12px 16px;
    font-size: 15px;
    color: var(--text-heading);
    background: transparent;
    border: none;
    outline: none;
    font-family: inherit;
  }

  .waitlist-form input::placeholder { color: var(--text-disabled); }

  .waitlist-form button {
    padding: 8px 18px;
    margin: 5px;
    font-size: 14px;
    font-weight: 600;
    color: var(--page-bg);
    background: var(--accent);
    border-radius: calc(var(--radius-sm) - 2px);
    white-space: nowrap;
    transition: background var(--transition);
    flex-shrink: 0;
  }

  .waitlist-form button:hover:not(:disabled) { background: var(--accent-hover); }
  .waitlist-form button:disabled { opacity: 0.7; cursor: not-allowed; }

  /* --- Hero screenshot wrapper (cloud + frame) --- */
  .hero-screenshot-wrap {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    overflow: visible;
  }

  .hero-segment {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }

  .hero-screenshot {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    box-shadow: 0 40px 80px hsla(7, 100%, 68%, 0.06), 0 0 0 1px var(--border-subtle);
  }

  .screenshot-carousel {
    position: relative;
    overflow: hidden;
  }

  .screenshot-slide {
    display: none;
    animation: slideFadeIn 350ms ease both;
  }

  .screenshot-slide.active {
    display: block;
  }

  @keyframes slideFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .screenshot-body {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .screenshot-body img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* --- Platforms --- */
  .platforms {
    display: flex;
    align-items: center;
