---
// Imprint / Impressum
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Imprint — n8n-desk</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
</head>
<body>

  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">n8n-desk</a>
    </div>
  </nav>

  <main class="legal">
    <h1>Impressum</h1>
    <p class="subtitle">Angaben gemass &sect; 5 TMG</p>

    <h2>Unternehmen</h2>
    <p>
      Industrial Code &amp; Magic UG (haftungsbeschrankt)<br />
      Vertretungsberechtigter: Marcel Claus-Ahrens (Geschaftsfuhrer)
    </p>

    <h2>Adresse</h2>
    <p>
      Industrial Code &amp; Magic UG (haftungsbeschrankt)<br />
      c/o Factory Works GmbH<br />
      Rheinsberger Strasse 76/77<br />
      10115 Berlin<br />
      Deutschland
    </p>

    <h2>Kontakt</h2>
    <p>
      E-Mail: <a href="mailto:mail@industrial-code-and-magic.com">mail@industrial-code-and-magic.com</a>
    </p>

    <h2>Registereintrag</h2>
    <p>
      Registergericht: Amtsgericht Charlottenburg<br />
      Registernummer: HRB 252778 B
    </p>

    <h2>Inhaltlich Verantwortlicher</h2>
    <p>
      Marcel Claus-Ahrens<br />
      (gemass &sect; 55 Abs. 2 RStV)
    </p>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">n8n-desk</span>
      <div class="footer-links">
        <a href="/imprint">Imprint</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/">Home</a>
      </div>
    </div>
  </footer>

  <style>
    :root {
      --neutral-125: hsl(0, 0%, 96%);
      --neutral-250: hsl(0, 0%, 80%);
      --neutral-300: hsl(0, 0%, 68%);
      --neutral-600: hsl(0, 0%, 46%);
      --neutral-800: hsl(0, 0%, 24%);
      --neutral-900: hsl(0, 0%, 13%);
      --neutral-950: hsl(0, 0%, 9%);
      --orange-300:  hsl(7, 100%, 68%);
      --orange-400:  hsl(7, 100%, 60%);

      --page-bg:        var(--neutral-950);
      --section-alt-bg: var(--neutral-900);
      --text-heading:   var(--neutral-125);
      --text-body:      var(--neutral-250);
      --text-muted:     var(--neutral-300);
      --text-disabled:  var(--neutral-600);
      --accent:         var(--orange-300);
      --accent-hover:   var(--orange-400);
      --border-subtle:  rgba(255, 255, 255, 0.05);
      --max-width: 1120px;
      --transition: 150ms ease;
    }

    html { -webkit-font-smoothing: antialiased; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--page-bg);
      color: var(--text-body);
      line-height: 1.7;
      margin: 0;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--accent-hover); }

    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(23, 23, 23, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-subtle);
    }
    .nav-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 14px 24px;
      display: flex;
      align-items: center;
    }
    .nav-logo {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 18px;
      color: var(--text-heading);
      text-decoration: none;
    }

    .legal {
      max-width: 720px;
      margin: 0 auto;
      padding: 120px 24px 80px;
    }
    .legal h1 {
      font-size: 32px;
      font-weight: 700;
      color: var(--text-heading);
      margin-bottom: 8px;
    }
    .legal .subtitle {
      color: var(--text-muted);
      margin-bottom: 40px;
    }
    .legal h2 {
      font-size: 18px;
      font-weight: 600;
      color: var(--text-heading);
      margin: 32px 0 12px;
    }
    .legal p {
      margin-bottom: 16px;
    }

    .footer {
      background: var(--section-alt-bg);
      padding: 40px 24px 24px;
      border-top: 1px solid var(--border-subtle);
    }
    .footer-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-logo {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 16px;
      color: var(--text-muted);
    }
    .footer-links {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .footer-links a {
      font-size: 14px;
      color: var(--text-disabled);
      transition: color var(--transition);
    }
    .footer-links a:hover { color: var(--accent); }
  </style>

</body>
</html>
